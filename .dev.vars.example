# Copy this to .dev.vars for local development (never commit .dev.vars)

ADMIN_PASSWORD=your-admin-password-here
SESSION_SECRET=your-32-byte-hex-secret-here

# Vault encryption (CRITICAL: back this up — losing it = losing all vault data)
VAULT_MASTER_KEY=your-32-byte-base64-vault-key-here

# Analytics APIs
YOUTUBE_API_KEY=
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=

# Cloudflare Turnstile (bot protection on login)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
