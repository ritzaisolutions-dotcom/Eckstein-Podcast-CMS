# Database (Neon Postgres — copy from Neon dashboard)
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Auth
ADMIN_PASSWORD=choose-a-strong-password
SESSION_SECRET=random-32-char-string

# Vault encryption (back this up in 1Password — loss = all vault data gone)
VAULT_MASTER_KEY=random-32-char-string

# Vercel Blob (auto-set by Vercel when you add Blob storage)
BLOB_READ_WRITE_TOKEN=

# Analytics APIs
YOUTUBE_API_KEY=
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_IDS=

# Cron protection (optional — set to require X-Cron-Secret header on analytics refresh)
CRON_SECRET=
